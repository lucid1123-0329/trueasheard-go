{
  "version": 2,
  "routes": [
    {
      "src": "/og-image.png",
      "dest": "/public/og-image.png"
    },
    {
      "src": "/api/proxy",
      "dest": "/api/proxy.js"
    },
    {
      "src": "^/$",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
